---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
	title="Contact — Adam Mooz"
	description="Get in touch with Adam Mooz."
	eyebrow="Contact"
>
	<section class="content-shell py-12 space-y-10">
		<div class="max-w-2xl space-y-3">
			<p class="m-0 text-ink text-2xl font-semibold leading-tight">
				Let's talk.
			</p>
			<p class="m-0 text-muted">
				Whether you have a project in mind, want to chat about engineering leadership,
				or just want to say hi — feel free to reach out. I try to reply to everything.
			</p>
		</div>

		<!-- Tally.so contact form embed -->
		<!-- Replace YOUR_FORM_ID below with your Tally.so form ID after creating a free form at https://tally.so -->
		<div class="max-w-2xl">
			<iframe
				data-tally-src="https://tally.so/embed/YOUR_FORM_ID?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
				loading="lazy"
				width="100%"
				height="300"
				frameborder="0"
				marginheight="0"
				marginwidth="0"
				title="Contact Adam Mooz"
			></iframe>
			<script>
				var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}
			</script>
		</div>

		<!-- Fallback: direct contact options -->
		<div class="max-w-2xl pt-4 border-t border-base-200 space-y-2">
			<h2 class="text-xs font-bold uppercase text-base-500 tracking-widest">Or reach me directly</h2>
			<ul class="space-y-1 list-none p-0">
				<li>
					<a class="text-sm text-ink font-bold uppercase hover:text-base-500" href="mailto:adam@mooz.ca">
						Email — adam@mooz.ca
					</a>
				</li>
				<li>
					<a class="text-sm text-ink font-bold uppercase hover:text-base-500" href="https://linkedin.com/in/adammooz/" target="_blank" rel="noreferrer">
						LinkedIn — adammooz
					</a>
				</li>
				<li>
					<a class="text-sm text-ink font-bold uppercase hover:text-base-500" href="https://twitter.com/AdamMooz" target="_blank" rel="noreferrer">
						Twitter / X — @AdamMooz
					</a>
				</li>
			</ul>
		</div>
	</section>
</PageLayout>
